graph TB
    subgraph macOS["macOS Menu System"]
        direction TB
        M1["Menu Bar at TOP OF SCREEN<br/>(Global, shared across windows)"]
        M2["Application Menu"]
        M3["• About<br/>• Preferences<br/>• Services<br/>• Quit"]
        M4["Keyboard: ⌘ (Command) key"]
        M1 --> M2 --> M3
        M1 -.-> M4
    end

    subgraph Windows["Windows Menu System"]
        direction TB
        W1["Menu Bar IN WINDOW<br/>(Below title bar, per-window)"]
        W2["File Menu + Help Menu"]
        W3["File: Exit<br/>Help: About"]
        W4["Keyboard: Alt + underlined letter"]
        W1 --> W2 --> W3
        W1 -.-> W4
    end

    subgraph Linux["Linux Menu System (GTK/GNOME)"]
        direction TB
        L1["Menu Bar VARIES<br/>(Top screen or in window)"]
        L2["File Menu + Help Menu"]
        L3["File: Quit<br/>Edit: Preferences<br/>Help: About"]
        L4["Keyboard: Ctrl key"]
        L1 --> L2 --> L3
        L1 -.-> L4
    end

    style M1 fill:#e3f2fd
    style W1 fill:#fff3e0
    style L1 fill:#f3e5f5
