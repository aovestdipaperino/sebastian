        direction TB
        R1["random u32<br/>0 to 4,294,967,295"] --> M1["% 6"]
        M1 --> B1["0: 715,827,883 values<br/>4: 715,827,882 values<br/>~0.00000014% bias"]
    end

    subgraph Right["Rejection Sampling (correct)"]
        direction TB
