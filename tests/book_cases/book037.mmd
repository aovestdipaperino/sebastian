flowchart TB
    subgraph Runtime["tokio-uring Runtime (single thread)"]
        direction TB
        subgraph Works["Works with io-uring"]
            N["tokio_uring::net<br/>TcpListener, TcpStream"]
            F["tokio_uring::fs<br/>File"]
        end
        subgraph Compat["Tokio ecosystem (compatible)"]
            CH["tokio::sync<br/>mpsc, oneshot, watch"]
            TM["tokio::time<br/>sleep, interval, timeout"]
            SE["tokio::select!<br/>race multiple futures"]
        end
        subgraph NoUring["Uses epoll, not io-uring"]
            TN["tokio::net<br/>TcpStream, UdpSocket"]
            TF["tokio::fs<br/>File"]
        end
    end

