flowchart TB
    subgraph LP["Length-Prefix (4-byte header)"]
        LP1["Two reads per message"]
        LP2["Variable message sizes"]
        LP3["Simple to implement"]
        LP1 --> LP2 --> LP3
    end

    subgraph FX["Fixed-Size Frames"]
        FX1["One read per message"]
        FX2["Predictable memory layout"]
        FX3["Wastes bandwidth on small payloads"]
        FX1 --> FX2 --> FX3
    end

    subgraph DL["Delimiter-Based"]
        DL1["Scan for terminator byte"]
        DL2["Efficient for text protocols"]
        DL3["Delimiter must not appear in payload"]
        DL1 --> DL2 --> DL3
    end

    subgraph TLV["TLV (Type-Length-Value)"]
        TLV1["Type field enables dispatch"]
        TLV2["Extensible without breaking receivers"]
        TLV3["More complex to parse"]
        TLV1 --> TLV2 --> TLV3
    end

    style LP fill:#e8f4e8,stroke:#2d7d2d,font-size:16px
