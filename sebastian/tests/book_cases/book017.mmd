flowchart TB
    subgraph CPU["CPU Profiling"]
        direction TB
        CP1["Samples taken on CPU timer"]
        CP2["Parked/waiting tasks: invisible"]
        CP3["Shows: compute hotspots, syscall overhead, lock contention"]
        CP1 --> CP2 --> CP3
    end

    subgraph Wall["Wall-Clock Profiling"]
        direction TB
        WP1["Samples taken on real time"]
        WP2["Parked tasks visible as sleeping frames"]
        WP3["Shows: starvation, long waits, deadlocks"]
        WP1 --> WP2 --> WP3
    end

    subgraph Console["tokio-console"]
        direction TB
        TC1["Instruments the Tokio runtime"]
        TC2["Shows per-task poll counts, wait times"]
        TC3["Shows: which tasks are slow, which are stuck"]
        TC1 --> TC2 --> TC3
    end

    style CPU fill:#e8e8f4,stroke:#2d2d7d,font-size:16px
    style Wall fill:#e8f4e8,stroke:#2d7d2d,font-size:16px
    style Console fill:#f4f4e8,stroke:#7d7d2d,font-size:16px
    style CP1 fill:#fff,stroke:#999,font-size:16px
    style CP2 fill:#fff,stroke:#999,font-size:16px
    style CP3 fill:#fff,stroke:#999,font-size:16px
    style WP1 fill:#fff,stroke:#999,font-size:16px
    style WP2 fill:#fff,stroke:#999,font-size:16px
    style WP3 fill:#fff,stroke:#999,font-size:16px
    style TC1 fill:#fff,stroke:#999,font-size:16px
    style TC2 fill:#fff,stroke:#999,font-size:16px
    style TC3 fill:#fff,stroke:#999,font-size:16px
