flowchart TB
    subgraph UserSpace["User Space"]
        direction TB
        App["Application\npushes SQEs"]
        CQPoll["Application\ndrains CQEs"]
    end

    subgraph Shared["Shared Memory (mmap)"]
        direction LR
        SQ["Submission Queue\n(SQEs: what to do)"]
        CQ["Completion Queue\n(CQEs: what happened)"]
    end

    subgraph Kernel["Kernel"]
        direction TB
        KProc["Kernel processes\nSQEs asynchronously"]
        KPost["Posts CQEs\non completion"]
        KProc --> KPost
    end

    App -->|"push"| SQ
    SQ -->|"io_uring_enter()"| KProc
    KPost -->|"write result"| CQ
    CQ -->|"read result + user_data"| CQPoll

    style UserSpace fill:#e8e8f4,stroke:#2d2d7d,font-size:16px
    style Shared fill:#f4f4e8,stroke:#7d7d2d,font-size:16px
    style Kernel fill:#f4e8e8,stroke:#7d2d2d,font-size:16px
    style App fill:#fff,stroke:#999,font-size:16px
    style CQPoll fill:#fff,stroke:#999,font-size:16px
    style SQ fill:#fff,stroke:#999,font-size:16px
    style CQ fill:#fff,stroke:#999,font-size:16px
    style KProc fill:#fff,stroke:#999,font-size:16px
    style KPost fill:#fff,stroke:#999,font-size:16px
